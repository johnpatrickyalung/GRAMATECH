# Copy to `.env` and set secrets. Required for `npm run server`.

# MongoDB Atlas — pick ONE style (same DB user must exist in Atlas → Database Access).
#
# SRV:
# MONGODB_URI=mongodb+srv://USER:YOUR_DB_PASSWORD@cluster0.fiferpp.mongodb.net/gramatech?retryWrites=true&w=majority&appName=Cluster0
#
# Standard seed list (from Atlas “Connect” → Drivers), database name before ?:
# MONGODB_URI=mongodb://USER:YOUR_DB_PASSWORD@ac-obopo9b-shard-00-00.fiferpp.mongodb.net:27017,ac-obopo9b-shard-00-01.fiferpp.mongodb.net:27017,ac-obopo9b-shard-00-02.fiferpp.mongodb.net:27017/gramatech?ssl=true&replicaSet=atlas-2lpej9-shard-0&authSource=admin&retryWrites=true&w=majority&appName=Cluster0
#
# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/gramatech
MONGODB_URI=mongodb+srv://USER:YOUR_DB_PASSWORD@cluster0.fiferpp.mongodb.net/gramatech?retryWrites=true&w=majority&appName=Cluster0

# Optional: Atlas Stable API (same as MongoDB “Connect” sample). Default is off.
# MONGODB_USE_STABLE_API=true

# DEBUG ONLY — if you get TLS/ssl3_read_bytes errors on Windows, try true once to see if antivirus/SSL inspection is the cause. Remove after testing.
# MONGODB_TLS_RELAXED=true

# Create empty MongoDB collections (admins, categories, words, sessions) if missing: npm run db:init

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# PORT=3001
# CLIENT_ORIGIN=https://your-app.example.com
