# GRAMATECH — environment variables example
# Copy this file to .env and fill in your values

# Supabase — get these from https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT — must be a long random string, keep secret
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# First admin account (auto-created on first server start if admins table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Optional: change the API port (default 3001)
# PORT=3001
